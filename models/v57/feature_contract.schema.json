{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AutoSafe v57 feature contract",
  "type": "object",
  "required": ["contract_type", "version", "history_window", "parity", "point_in_time_rule", "features"],
  "properties": {
    "contract_type": {"const": "autosafe_feature_contract"},
    "version": {"type": "string", "pattern": "^v57"},
    "history_window": {
      "type": "object",
      "required": ["start", "rule"],
      "properties": {
        "start": {"type": "string", "format": "date"},
        "rule": {"type": "string"}
      }
    },
    "parity": {
      "type": "object",
      "required": ["tolerance"],
      "properties": {"tolerance": {"type": "number", "exclusiveMinimum": 0}}
    },
    "point_in_time_rule": {"type": "string", "minLength": 10},
    "artifact_dependencies": {"type": "array", "items": {"type": "string"}},
    "decision_provenance": {"type": "object"},
    "features": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "dtype", "default", "source", "prediction_time_available"],
        "properties": {
          "name": {"type": "string", "minLength": 1},
          "dtype": {"enum": ["float", "int", "categorical"]},
          "default": {},
          "source": {"type": "string", "description": "Upstream column / computation that produces this feature"},
          "prediction_time_available": {"type": "boolean"},
          "window_bounded": {"type": "boolean", "description": "True if computed over the capped observation window"},
          "description": {"type": "string"}
        }
      }
    }
  }
}
